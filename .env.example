# Database URL — pick one:
#
# A) Supabase CLI — local stack (needs Docker): `npm run supabase:start`
#    postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# B) Supabase CLI — cloud project (link + Drizzle on the same DB)
#    1. npm run supabase:login
#    2. npm run supabase:projects   → copy REFERENCE ID for the project you want
#    3. npm run supabase:link -- --project-ref YOUR_REF
#       (password prompt = Database password from Supabase Dashboard → Settings → Database;
#        non-interactive: set env SUPABASE_DB_PASSWORD before link — see CLI docs)
#    4. In Dashboard → Database → Connection string, copy the URI. Prefer "Direct"
#       for `npm run db:push`; append ?sslmode=require if not already present.
#    5. Paste that URI as DATABASE_URL in .env.local, then: npm run db:push && npm run db:seed
#
# C) Plain Postgres / docker-compose: postgres://postgres:postgres@localhost:5432/ai_governance
#
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-chars-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"

# Public URL for the Better Auth client (same origin in dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: product title in auth pages / nav
# NEXT_PUBLIC_APP_NAME="AI Governance"

# Tenant for new signups — production must set one of these (must exist after seed/migrate):
DEFAULT_ORGANIZATION_ID="org_demo"
# DEFAULT_ORGANIZATION_SLUG="demo"

# Optional: override seed org id (defaults to org_demo). Keep in sync with DEFAULT_ORGANIZATION_ID when custom.
# SEED_ORGANIZATION_ID=org_demo

# Production DB: use sslmode=require or verify-full; never sslmode=no-verify.
# Local/dev workaround if TLS chain fails: sslmode=no-verify (not for production).

# Optional: POST /api/v1/requests — requests per rolling minute (in-memory per server)
# AGENT_API_RATE_LIMIT_IP_PER_MIN=120
# AGENT_API_RATE_LIMIT_KEY_PER_MIN=60

# Optional: HTTP policy adapter (OPA / OpenFGA sidecar, etc.)
# POLICY_ENGINE_URL=https://policy.internal/evaluate

# Optional: approver / requester email (Resend HTTP API). Without RESEND_API_KEY, bodies log to console in dev.
# RESEND_API_KEY=
# EMAIL_FROM="Governance <noreply@example.com>"
# Optional separate secret for signed email approve/decline links (else BETTER_AUTH_SECRET is used)
# APPROVAL_EMAIL_SECRET=

# Optional: POST /api/v1/ingest/chat — bot relay (set both to enable)
# CHAT_INGEST_SECRET=long-random-string
# CHAT_INGEST_ORG_ID=org_demo

# Optional: fulfillment worker auth (drain pending fulfillment_job rows)
# CRON_SECRET=long-random-string

# Optional: Slack interactivity signing (POST /api/integrations/slack/interactions)
# SLACK_SIGNING_SECRET=

# Optional: encrypt webhook signing secret at rest (32 bytes, base64). Use KMS-wrapped DEK in prod.
# FIELD_ENCRYPTION_KEY=

# Fulfillment: stub (dev/E2E), log (debug), or http_webhook (production).
# PROVISION_CONNECTOR=stub
# Production: use http_webhook + PROVISION_WEBHOOK_URL, or set ALLOW_STUB_PROVISION=true (staging only).
# PROVISION_WEBHOOK_URL=https://your-automation.example/hooks/provision
# PROVISION_WEBHOOK_BEARER=optional-bearer-token-for-downstream
# ALLOW_STUB_PROVISION=true

# --- AI (onboarding copilot + home chat) ---
# Per-org keys: Admin → AI in the app. Optional platform fallback for all orgs without BYOK:
# APP_AI_PLATFORM_API_KEY=
# APP_AI_PLATFORM_BASE_URL=https://openrouter.ai/api/v1
# APP_AI_PLATFORM_MODEL=openai/gpt-4o-mini
# Production: allow fallback only when explicitly enabled:
# ALLOW_AI_PLATFORM_FALLBACK=true

# E2E / CI: skip live LLM calls in server actions that honor TEST_AI_MOCK
# TEST_AI_MOCK=1
